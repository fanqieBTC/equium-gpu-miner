+/// Persistent CUDA solver child process. Keeps CUDA context alive across
+/// rounds, communicating via stdin/stdout JSON lines.
+struct CudaDaemon {
+    child: Child,
+    stdin: BufWriter<ChildStdin>,
+    stdout: BufReader<ChildStdout>,
+}
+
+impl CudaDaemon {
+    fn spawn(path: &Path) -> Result<Self> {
+        let mut child = Command::new(path)
+            .arg("--daemon")
+            .stdin(Stdio::piped())
+            .stdout(Stdio::piped())
+            .stderr(Stdio::inherit())
+            .spawn()
+            .with_context(|| format!("spawn CUDA daemon {}", path.display()))?;
+
+        let stdin = BufWriter::new(
+            child.stdin.take().ok_or_else(|| anyhow!("no stdin"))?,
+        );
+        let mut stdout = BufReader::new(
+            child.stdout.take().ok_or_else(|| anyhow!("no stdout"))?,
+        );
+
+        // Wait for the "ready" handshake.
+        let mut line = String::new();
+        stdout
+            .read_line(&mut line)
+            .context("read CUDA daemon ready")?;
+        let resp: CudaSolverResponse =
+            serde_json::from_str(line.trim()).context("parse CUDA daemon ready")?;
+        if resp.kind != "ready" {
+            return Err(anyhow!(
+                "expected CUDA daemon ready, got: {}",
+                line.trim()
+            ));
+        }
+
+        Ok(Self {
+            child,
+            stdin,
+            stdout,
+        })
+    }
+
+    fn solve(
+        &mut self,
+        input: &[u8],
+        max_nonces: u64,
+        target: Option<&[u8; 32]>,
+    ) -> Result<(Option<RaceWinner>, u64)> {
+        let mut cmd = format!(
+            "{{\"cmd\":\"solve\",\"input\":\"0x{}\",\"max_nonces\":{}",
+            hex::encode(input),
+            max_nonces,
+        );
+        if let Some(t) = target {
+            cmd.push_str(&format!(",\"target\":\"0x{}\"", hex::encode(t)));
+        }
+        cmd.push_str("}\n");
+
+        self.stdin
+            .write_all(cmd.as_bytes())
+            .context("write to CUDA daemon")?;
+        self.stdin.flush().context("flush CUDA daemon stdin")?;
+
+        let mut line = String::new();
+        self.stdout
+            .read_line(&mut line)
+            .context("read from CUDA daemon")?;
+        let resp: CudaSolverResponse =
+            serde_json::from_str(line.trim())
+                .with_context(|| format!("parse CUDA daemon JSON: {}", line.trim()))?;
+
+        match resp.kind.as_str() {
+            "found" => {
+                let nonce_hex = resp
+                    .nonce
+                    .ok_or_else(|| anyhow!("solver response missing nonce"))?;
+                let soln_hex = resp
+                    .soln_indices
+                    .ok_or_else(|| anyhow!("solver response missing soln_indices"))?;
+                let nonce_vec = parse_hex_vec(&nonce_hex, 32, "nonce")?;
+                let soln_indices = parse_hex_vec(&soln_hex, 68, "soln_indices")?;
+                let mut nonce = [0u8; 32];
+                nonce.copy_from_slice(&nonce_vec);
+                Ok((
+                    Some(RaceWinner {
+                        nonce,
+                        soln_indices,
+                    }),
+                    resp.attempts,
+                ))
+            }
+            "not_found" => Ok((None, resp.attempts)),
+            "error" => Err(anyhow!(
+                "solver error: {}",
+                resp.message.unwrap_or_else(|| "unknown".into())
+            )),
+            other => Err(anyhow!("unknown solver response type: {}", other)),
+        }
+    }
+
+    fn shutdown(mut self) {
+        let _ = self.stdin.write_all(b"{\"cmd\":\"quit\"}\n");
+        let _ = self.stdin.flush();
+        let _ = self.child.wait();
+    }
 }
 
