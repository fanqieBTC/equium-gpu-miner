+//! Verify a supplied Equium Equihash solution.
+//!
+//! Usage:
+//!   cargo run -p equihash-core --features solver --example verify_solution -- \
+//!     --input-hex <81-byte-hex> \
+//!     --nonce-hex <32-byte-hex> \
+//!     --soln-hex <68-byte-hex>
+
+use std::env;
+
+use equihash_core::challenge::I_LEN;
+use equihash_core::verify;
+use equihash_core::{DEFAULT_K, DEFAULT_N};
+
+fn arg_value(args: &[String], key: &str) -> Option<String> {
+    args.windows(2).find(|pair| pair[0] == key).map(|pair| pair[1].clone())
+}
+
+fn decode_hex(value: &str, expected: usize, label: &str) -> Vec<u8> {
+    let hex = value.strip_prefix("0x").unwrap_or(value);
+    let bytes = hex::decode(hex).unwrap_or_else(|e| panic!("decode {label}: {e}"));
+    assert_eq!(
+        bytes.len(),
+        expected,
+        "{label} must be {expected} bytes, got {}",
+        bytes.len()
+    );
+    bytes
+}
+
+fn main() {
+    let args: Vec<String> = env::args().collect();
+    let input_hex = arg_value(&args, "--input-hex").expect("--input-hex is required");
+    let nonce_hex = arg_value(&args, "--nonce-hex").expect("--nonce-hex is required");
+    let soln_hex = arg_value(&args, "--soln-hex").expect("--soln-hex is required");
+    let target_hex = arg_value(&args, "--target-hex")
+        .unwrap_or_else(|| "ff".repeat(32));
+
+    let input_vec = decode_hex(&input_hex, I_LEN, "input");
+    let nonce_vec = decode_hex(&nonce_hex, 32, "nonce");
+    let soln_indices = decode_hex(&soln_hex, 68, "soln_indices");
+    let target_vec = decode_hex(&target_hex, 32, "target");
+
+    let mut input = [0u8; I_LEN];
+    input.copy_from_slice(&input_vec);
+    let mut nonce = [0u8; 32];
+    nonce.copy_from_slice(&nonce_vec);
+    let mut target = [0u8; 32];
+    target.copy_from_slice(&target_vec);
+
+    match verify::verify(DEFAULT_N, DEFAULT_K, &input, &nonce, &soln_indices, &target) {
+        Ok(hash) => println!(
+            "{{\"valid\":true,\"hash\":\"0x{}\"}}",
+            hex::encode(hash)
+        ),
+        Err(error) => {
+            println!("{{\"valid\":false,\"error\":\"{:?}\"}}", error);
+            std::process::exit(1);
+        }
+    }
+}
