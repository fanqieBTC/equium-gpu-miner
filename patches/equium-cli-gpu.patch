+fn read_miner_keypair(path: &Path) -> Result<Keypair> {
+    match read_keypair_file(path) {
+        Ok(keypair) => Ok(keypair),
+        Err(json_err) => {
+            let raw = fs::read_to_string(path)
+                .with_context(|| format!("read keypair {}", path.display()))?;
+            let trimmed = raw.trim();
+            if trimmed.is_empty() {
+                return Err(anyhow!("read keypair {}: file is empty", path.display()));
+            }
+
+            let bytes = bs58::decode(trimmed).into_vec().map_err(|base58_err| {
+                anyhow!(
+                    "read keypair {}: expected Solana JSON array or base58 secret key; JSON error: {}; base58 error: {}",
+                    path.display(),
+                    json_err,
+                    base58_err
+                )
+            })?;
+
+            Keypair::from_bytes(&bytes).map_err(|keypair_err| {
+                anyhow!(
+                    "read keypair {}: invalid base58 secret key: {}",
+                    path.display(),
+                    keypair_err
+                )
+            })
+        }
+    }
+}
+
+fn resolve_engine(engine: &str) -> SolverEngine {
+    match engine.to_ascii_lowercase().as_str() {
+        "auto" | "cpu" => SolverEngine::Cpu,
+        "gpu" | "cuda" => {
+            if cuda_solver_path().is_some() {
+                SolverEngine::Cuda
+            } else {
+                eprintln!(
+                    "warning: --engine {} requested but equium-cuda-solver was not found; falling back to CPU worker pool.",
+                    engine
+                );
+                SolverEngine::Cpu
+            }
+        }
+        "metal" => {
+            eprintln!(
+                "warning: Metal Equihash backend is not implemented yet; falling back to CPU worker pool."
+            );
+            SolverEngine::Cpu
+        }
+        other => {
+            eprintln!(
+                "warning: unknown --engine '{}'; use auto, cpu, gpu, cuda, or metal. falling back to CPU.",
+                other
+            );
+            SolverEngine::Cpu
+        }
+    }
+}
+
+fn cuda_solver_path() -> Option<PathBuf> {
+    if let Ok(path) = std::env::var("EQUIUM_CUDA_SOLVER") {
+        let p = PathBuf::from(path);
+        if p.is_file() {
+            return Some(p);
+        }
+    }
+
+    let candidates = [
+        PathBuf::from("clients/cuda-solver/equium-cuda-solver"),
+        PathBuf::from("./equium-cuda-solver"),
+        std::env::current_exe()
+            .ok()
+            .and_then(|p| p.parent().map(|dir| dir.join("equium-cuda-solver")))
+            .unwrap_or_else(|| PathBuf::from("target/release/equium-cuda-solver")),
+    ];
+
+    candidates.into_iter().find(|path| path.is_file())
+}
+
+fn parse_hex_vec(value: &str, expected: usize, label: &str) -> Result<Vec<u8>> {
+    let hex = value.strip_prefix("0x").unwrap_or(value);
+    if hex.len() != expected * 2 {
+        return Err(anyhow!(
+            "{} must be {} bytes, got {} hex chars",
+            label,
+            expected,
+            hex.len()
+        ));
+    }
+    Ok(hex::decode(hex).with_context(|| format!("decode {}", label))?)
+}
+
+fn env_u64(name: &str, default: u64) -> u64 {
+    std::env::var(name)
+        .ok()
+        .and_then(|v| v.parse::<u64>().ok())
+        .unwrap_or(default)
+}
